APP_NAME=دانشیار | موتور هوشمند محتوای آموزشی
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATA_DIR=./data
MAX_UPLOAD_MB=50
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
TOP_K=6

# Optional. The app remains runnable without an API key by using local extractive fallbacks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
USE_OPENAI_EMBEDDINGS=false

# Set true only behind a trusted reverse proxy that terminates HTTPS.
TRUST_PROXY_HEADERS=false
