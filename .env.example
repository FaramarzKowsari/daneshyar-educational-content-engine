APP_NAME=دانشیار | موتور هوشمند محتوای آموزشی
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
DATA_DIR=./data

# Optional PostgreSQL connection. Leave empty for local SQLite.
DATABASE_URL=

# Public-beta safety limits
MAX_UPLOAD_MB=25
MAX_PDF_PAGES=250
PUBLIC_BOOK_TTL_HOURS=24
PUBLIC_UPLOADS_PER_HOUR=3
PUBLIC_CHAT_PER_HOUR=30
PUBLIC_GENERATIONS_PER_HOUR=12

CHUNK_SIZE=1200
CHUNK_OVERLAP=180
TOP_K=6

# OCR for scanned Persian/English PDFs (Docker image includes Tesseract languages)
ENABLE_OCR=true
OCR_LANGUAGES=fas+eng
OCR_MAX_PAGES=60
OCR_DPI=180

# Optional OpenAI generation. Keep the key on the server only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
USE_OPENAI_EMBEDDINGS=false

# Only needed if the frontend is hosted on another domain.
# Example: https://faramarzkowsari.github.io
ALLOWED_ORIGINS=
TRUST_PROXY_HEADERS=true
